DATABASE_URL=postgres://cex_router:cex_router@db:5432/cex_router?sslmode=disable
LOG_LEVEL=info

# API
LISTEN_ADDR=:8080
CORS_ALLOWED_ORIGINS=*
RATE_LIMIT_PER_MIN=60
INTERNAL_METRICS_TOKEN=

# Ingester
# When unset, the default set uses public exchange endpoints:
# bithumb,bitget,kucoin,gate,htx,coinex,whitebit,bitmart
# Binance and Bybit are auto-added to that default when both matching read-only keys are present.
# For main venue coverage only, set:
# INGESTER_EXCHANGES=binance,bybit,bitget,gate
INGESTER_MAX_CONCURRENCY=4
INGESTER_RUN_ONCE=false
POLL_INTERVAL_SECONDS=30
POLL_TIMEOUT_SECONDS=10

# Optional private/read-only exchange credentials.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
UPBIT_API_KEY=
UPBIT_API_SECRET=

# Optional endpoint overrides.
BINANCE_BASE_URL=https://api.binance.com
BITGET_BASE_URL=https://api.bitget.com
BITMART_BASE_URL=https://api-cloud.bitmart.com
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_RECV_WINDOW=10000
BYBIT_REFERER=
COINEX_BASE_URL=https://api.coinex.com
GATE_BASE_URL=https://api.gateio.ws
HTX_BASE_URL=https://api.huobi.pro
KUCOIN_BASE_URL=https://api.kucoin.com
OKX_BASE_URL=https://www.okx.com
OKX_SIMULATED_TRADING=false
UPBIT_BASE_URL=https://api.upbit.com
WHITEBIT_BASE_URL=https://whitebit.com

# Telegram bot
TELEGRAM_BOT_TOKEN=
# Comma-separated list of allowed chat IDs (numeric). Empty = open to any chat
# (only safe for private testing — set this in production).
TELEGRAM_ALLOWED_CHATS=

# Optional normalization audit enrichment.
CMC_API_KEY=
